# Copy to .env for local runs. Do not commit real secrets.

# Strongly recommended: avoids GitHub anonymous API rate limits.
# Fine-grained PAT can be read-only public repository metadata.
GITHUB_TOKEN=

# Strongly recommended: Reddit public JSON often returns 403.
# Create a Reddit script/web app and use client_credentials OAuth.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=smart-hardware-radar/1.0 by your-reddit-username

# Optional: improves category extraction quality; heuristic fallback works without it.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini

# Optional tuning.
GOOGLE_TRENDS_GEOS=US
GITHUB_TOOLCHAIN_MIN_STARS=50
GITHUB_HARDWARE_BRIDGE_MIN_STARS=10
GITHUB_AGENTIC_EDGE_MIN_STARS=25
SOURCE_SCAN_LIMIT=120
SOURCE_SCAN_PER_SOURCE_LIMIT=20
